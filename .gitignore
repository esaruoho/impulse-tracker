# compiled code and listings
*.OBJ
*.obj
*.EXE
*.exe
*.MAP
*.map
*.LST
*.lst
# don't ignore source.lst (not an assembler listing!)
!source.lst

# audio drivers
*.DRV
*.drv
*.MMX
*.mmx
*.3DN
*.3dn

# network driver
*.NET
*.net

# macOS
.DS_Store
VSound/.DS_Store

# local build toolchain (TASM/TLINK/MAKE — proprietary, fetched out-of-band)
tools/
tools-local/

# stray DOS redirect artifacts (DOSBox-X COMMAND.COM doesn't grok 2>&1
# and occasionally drops files named after redirect tokens it couldn't parse)
&1
SoundDrivers/&1
Network/&1
copy
SoundDrivers/copy
Network/copy
*.LOGcd
D.TXT
DRV.LOG
DRV_DONE.TXT
DRV_SND.LOG
DRV_NET.LOG
BUILDALL.LOG
BUILDALL.STAT

# local DOSBox-X driver config (paths machine-specific; example shipped as buildall.conf.sample)
buildall.conf
run.conf

# DOSBox-X build artifacts
BUILD_ST.TXT
MAKE.LOG
MDATA.LOG
DIAG*.LOG

# Local test artifacts
testp2.conf
OUTPUT.*
004_*.it
004_*.001
CACHE.ITS

# WAV render outputs + Ctrl-O log — produced by running IT.EXE (Quicksave
# renders land here when no Quicksave folder is configured). Never commit.
*.WAV
*.wav
CTRLOLOG.TXT
CTRLOLOG.OLD

# personal IT.CFG kept in repo root for zip staging (canonical copy lives on
# /Volumes/AIFORIA2/IT.CFG and is bundled into every IT2354-esaruoho-<sha>.zip).
# Holds user-specific MIDI ports, sound-driver pick, Quicksave path, envelope
# presets — do NOT commit.
IT.CFG

# Local release/build artifacts — these are produced by builds and the GitHub
# Actions release; they should never be committed.
IT2354-esaruoho-*.zip
IT-V*.zip
dosbox-test/
dosbox-test.conf

# Convey SessionEnd distiller — local proof-of-fire log
features/sessions/.distill-log

# Convey distiller: last raw SessionEnd payload (proof-of-fire, local)
features/sessions/.last-payload.json

# Python bytecode (Convey generators)
features/__pycache__/
*.pyc

# Convey auto-written per-session stubs are LOCAL (promote to a real .session.md to keep)
features/sessions/*.md
!features/sessions/README.md
